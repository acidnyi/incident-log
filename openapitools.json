{
    "$schema": "./node_modules/@openapitools/openapi-generator-cli/config.schema.json",
    "generator-cli": {
        "useDocker": true,
        "version": "6.6.0",
        "generators": {
            "incident-log": {
                "generatorName": "typescript-fetch",
                "glob": "api/incident-log.openapi.yaml",
                "output": "#{cwd}/src/api/incident-log",
                "additionalProperties": {
                    "supportsES6": "true",
                    "withInterfaces": true
                }
            }
        }
    }
}